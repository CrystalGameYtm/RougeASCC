<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="RougeASCC.Views.SettingsControl"
             Background="Black">
    
    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="20">
        <TextBlock Text="НАЛАШТУВАННЯ" FontSize="48" Foreground="Cyan" 
                   HorizontalAlignment="Center" FontWeight="Bold" Margin="0,0,0,30"/>
        
        <TextBlock Text="Музика та Звук (в розробці)" Foreground="Gray" FontSize="18" HorizontalAlignment="Center"/>
        
        <Button Content="ПОВЕРНУТИСЯ" Width="250" Height="50" Margin="0,40,0,0"
                Background="#222222" Foreground="White" BorderBrush="Red" BorderThickness="1"
                HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                Click="Back_Click"/>
    </StackPanel>
</UserControl>